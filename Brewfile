# Toolchain for Buzz. Install with: brew bundle
brew "xcodegen"          # generates Buzz.xcodeproj from project.yml
brew "swiftlint"         # Swift style + correctness enforcement
brew "swiftformat"       # code formatting
brew "gitleaks"          # secret scanning before commit/push
brew "supabase/tap/supabase"   # local Supabase (Postgres + PostGIS + auth)
brew "xcpretty"          # prettier xcodebuild output
brew "fastlane"          # TestFlight / App Store automation
