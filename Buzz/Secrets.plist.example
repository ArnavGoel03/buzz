<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy this file to `Secrets.plist` (already gitignored) and fill in your credentials.
  NEVER commit Secrets.plist. Never paste credentials into source files.
-->
<plist version="1.0">
<dict>
    <key>SUPABASE_URL</key>
    <string>REPLACE_ME_https://YOUR-PROJECT.supabase.co</string>

    <key>SUPABASE_ANON_KEY</key>
    <string>REPLACE_ME_eyJhbGc...your-anon-key</string>

    <key>SENTRY_DSN</key>
    <string>REPLACE_ME_https://...@sentry.io/...</string>

    <key>POSTHOG_API_KEY</key>
    <string>REPLACE_ME_phc_...</string>
</dict>
</plist>
