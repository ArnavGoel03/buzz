{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buzz",
  "version": "1.0.0",
  "identifier": "com.arnavgoel.buzz",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Buzz",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://buzz.app https://*.supabase.co https://*.supabase.in; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: wss:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Live college events on your campus.",
    "longDescription": "Buzz — every college event, one feed. Live discovery of parties, clubs, sports, free food, and academic events happening tonight on and around campus.",
    "copyright": "© 2026 Arnav Goel",
    "publisher": "Arnav Goel",
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": null
    }
  }
}
